{
  "expo": {
    "name": "KrokomierzRN",
    "slug": "KrokomierzRN",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "krokomierzrn",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMotionUsageDescription": "Aplikacja wymaga dostępu do czujnika ruchu, aby zliczać Twoje kroki."
      }
    },
    "android": {
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBaDz42nULE9a1P3lsvwcvHdQ3TpmMxa0s"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.ACTIVITY_RECOGNITION"],
      "package": "com.anonymous.KrokomierzRN"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-sensors",
        {
          "motionPermission": "Aplikacja wymaga dostępu do czujnika ruchu, aby zliczać Twoje kroki."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
